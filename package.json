{
	"name": "react-native-skia-yoga",
	"version": "0.0.1",
	"description": "RNSkiaYoga",
	"main": "src/index",
	"module": "src/index",
	"types": "index.d.ts",
	"react-native": "src/index",
	"source": "src/index",
	"files": [
		"src",
		"index.d.ts",
		"react-native.config.js",
		"cpp",
		"nitrogen",
		"android/build.gradle",
		"android/fix-prefab.gradle",
		"android/gradle.properties",
		"android/CMakeLists.txt",
		"android/src",
		"ios/**/*.h",
		"ios/**/*.m",
		"ios/**/*.mm",
		"ios/**/*.cpp",
		"ios/**/*.swift",
		"jsx-runtime.js",
		"jsx-runtime.d.ts",
		"jsx-dev-runtime.js",
		"jsx-dev-runtime.d.ts",
		"nitro.json",
		"*.podspec",
		"README.md"
	],
	"scripts": {
		"typecheck": "tsc --noEmit",
		"check:install-isolation": "node ./scripts/verify-install-isolation.mjs",
		"check:android-skia-archives": "node ./scripts/verify-android-skia-archives.mjs",
		"check:yoganode-native-lifetime": "node ./scripts/verify-yoganode-native-lifetime.mjs",
		"check:package-lifecycle": "node ./scripts/verify-package-lifecycle.mjs",
		"check:package-surface": "node ./scripts/verify-package-surface.mjs",
		"check:package-typescript-consumer": "node ./scripts/verify-package-typescript-consumer.mjs",
		"check:skia-yoga-object-lazy-init": "node ./scripts/verify-skia-yoga-object-lazy-init.mjs",
		"check:example-bundle": "node ./scripts/verify-example-bundle-export.mjs",
		"check:rn-skia-imports": "node ./scripts/verify-rn-skia-imports.mjs",
		"check:yoganode-native-runtime": "node ./scripts/verify-yoganode-native-runtime-smoke.mjs",
		"clean": "rm -rf android/build node_modules/**/android/build lib",
		"lint": "eslint --resolve-plugins-relative-to ./node_modules/@react-native/eslint-config \".eslintrc.js\" \"**/*.{js,mjs,ts,tsx}\" --fix",
		"lint-ci": "eslint --resolve-plugins-relative-to ./node_modules/@react-native/eslint-config \".eslintrc.js\" \"**/*.{js,mjs,ts,tsx}\"",
		"typescript": "tsc",
		"specs": "nitrogen --logLevel=\"debug\"",
		"sync:example-links": "node ./scripts/sync-example-links.mjs --root --example"
	},
	"keywords": [
		"react-native",
		"nitro"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/SamuelScheit/react-native-skia-yoga.git"
	},
	"author": "Marc Rousavy <me@mrousavy.com> (https://github.com/mrousavy)",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/SamuelScheit/react-native-skia-yoga/issues"
	},
	"homepage": "https://github.com/SamuelScheit/react-native-skia-yoga#readme",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"devDependencies": {
		"@react-native/eslint-config": "0.80.1",
		"@types/jest": "^29.5.12",
		"@types/react": "^19.0.6",
		"eslint": "^8.57.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-prettier": "^5.2.1",
		"nitrogen": "^0.29.6",
		"prettier": "^3.3.3",
		"typescript": "^5.5.4"
	},
	"peerDependencies": {
		"react-native-gesture-handler": "*",
		"react": "*",
		"react-native": "*",
		"react-native-reanimated": "^4",
		"@shopify/react-native-skia": "*",
		"react-native-worklets": "*"
	},
	"codegenConfig": {
		"name": "RNSkiaYogaSpec",
		"type": "all",
		"jsSrcsDir": "./src/specs",
		"android": {
			"javaPackageName": "com.margelo.nitro.skiayoga"
		},
		"ios": {
			"componentProvider": {
				"SkiaYogaView": "SkiaYogaView"
			}
		}
	},
	"prettier": {
		"singleQuote": false,
		"tabWidth": 4,
		"useTabs": true,
		"semi": false
	},
	"trustedDependencies": [
		"nitro-codegen",
		"react-native-nitro-modules"
	],
	"dependencies": {
		"@types/react-reconciler": "^0.32.1",
		"react-native-nitro-modules": "^0.35.0",
		"react-reconciler": "0.31.0"
	}
}
