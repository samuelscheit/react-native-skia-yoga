{
	"name": "react-native-skia-yoga",
	"version": "0.0.1",
	"description": "RNSkiaYoga",
	"main": "src/index",
	"module": "src/index",
	"types": "index.d.ts",
	"react-native": "src/index",
	"source": "src/index",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"react-native": "./src/index.ts",
			"source": "./src/index.ts",
			"import": "./src/index.ts",
			"require": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./jsx-runtime": {
			"types": "./jsx-runtime.d.ts",
			"import": "./jsx-runtime.js",
			"require": "./jsx-runtime.js",
			"default": "./jsx-runtime.js"
		},
		"./jsx-dev-runtime": {
			"types": "./jsx-dev-runtime.d.ts",
			"import": "./jsx-dev-runtime.js",
			"require": "./jsx-dev-runtime.js",
			"default": "./jsx-dev-runtime.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"src",
		"index.d.ts",
		"react-native.config.js",
		"cpp",
		"nitrogen",
		"android/build.gradle",
		"android/fix-prefab.gradle",
		"android/gradle.properties",
		"android/CMakeLists.txt",
		"android/src",
		"ios/**/*.h",
		"ios/**/*.m",
		"ios/**/*.mm",
		"ios/**/*.cpp",
		"ios/**/*.swift",
		"jsx-runtime.js",
		"jsx-runtime.d.ts",
		"jsx-dev-runtime.js",
		"jsx-dev-runtime.d.ts",
		"nitro.json",
		"*.podspec",
		"README.md"
	],
	"scripts": {
		"typecheck": "tsc --noEmit",
		"clean": "rm -rf android/build node_modules/**/android/build lib",
		"lint": "eslint --resolve-plugins-relative-to ./node_modules/@react-native/eslint-config \".eslintrc.js\" \"**/*.{js,mjs,ts,tsx}\" --fix",
		"lint-ci": "eslint --resolve-plugins-relative-to ./node_modules/@react-native/eslint-config \".eslintrc.js\" \"**/*.{js,mjs,ts,tsx}\"",
		"typescript": "tsc",
		"specs": "nitrogen --logLevel=\"debug\"",
		"sync:example-links": "node ./scripts/sync-example-links.mjs --root --example"
	},
	"keywords": [
		"react-native",
		"nitro"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/SamuelScheit/react-native-skia-yoga.git"
	},
	"author": "Samuel Scheit <github@samuelscheit.com> (https://samuelscheit.com/)",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/SamuelScheit/react-native-skia-yoga/issues"
	},
	"homepage": "https://github.com/SamuelScheit/react-native-skia-yoga#readme",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"devDependencies": {
		"@babel/core": "7.29.7",
		"@babel/plugin-transform-typescript": "7.29.7",
		"@react-native/eslint-config": "0.80.1",
		"@types/jest": "29.5.14",
		"@types/react": "19.2.17",
		"eslint": "8.57.1",
		"eslint-config-prettier": "9.1.2",
		"eslint-plugin-prettier": "5.5.6",
		"nitrogen": "0.29.8",
		"prettier": "3.8.4",
		"react-native-worklets": "0.5.1",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"react-native-gesture-handler": "2.31.1",
		"react": "19.1.0",
		"react-native": "0.80.1",
		"react-native-reanimated": "4.1.0",
		"@shopify/react-native-skia": "2.5.1",
		"react-native-worklets": "*"
	},
	"codegenConfig": {
		"name": "RNSkiaYogaSpec",
		"type": "all",
		"jsSrcsDir": "./src/specs",
		"android": {
			"javaPackageName": "com.margelo.nitro.skiayoga"
		},
		"ios": {
			"componentProvider": {
				"SkiaYogaView": "SkiaYogaView"
			}
		}
	},
	"prettier": {
		"singleQuote": false,
		"tabWidth": 4,
		"useTabs": true,
		"semi": false
	},
	"trustedDependencies": [
		"nitro-codegen",
		"react-native-nitro-modules"
	],
	"dependencies": {
		"@types/react-reconciler": "0.32.3",
		"react-native-nitro-modules": "0.35.10",
		"react-reconciler": "0.31.0"
	}
}
