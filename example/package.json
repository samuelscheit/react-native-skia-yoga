{
	"name": "react-native-skia-yoga-example",
	"main": "expo-router/entry",
	"version": "1.0.0",
	"scripts": {
		"start": "expo start",
		"reset-project": "node ./scripts/reset-project.js",
		"android": "expo run:android",
		"ios": "expo run:ios",
		"web": "expo start --web",
		"lint": "expo lint",
		"typecheck": "tsc -p tsconfig.skiayoga.json --noEmit",
		"postinstall": "rm node_modules/react-native-skia-yoga; ln -s ../../ node_modules/react-native-skia-yoga; bun ../scripts/sync-example-links.mjs"
	},
	"dependencies": {
		"@expo/vector-icons": "^15.1.1",
		"@react-navigation/bottom-tabs": "^7.4.0",
		"@react-navigation/elements": "^2.9.10",
		"@react-navigation/native": "^7.1.8",
		"@shopify/react-native-skia": "^2.5.1",
		"babel-plugin-module-resolver": "^5.0.2",
		"expo": "^55.0.0",
		"expo-blur": "~55.0.9",
		"expo-constants": "~55.0.7",
		"expo-font": "~55.0.4",
		"expo-haptics": "~55.0.8",
		"expo-image": "~55.0.6",
		"expo-linking": "~55.0.7",
		"expo-router": "~55.0.5",
		"expo-splash-screen": "~55.0.10",
		"expo-status-bar": "~55.0.4",
		"expo-symbols": "~55.0.5",
		"expo-system-ui": "~55.0.9",
		"expo-web-browser": "~55.0.9",
		"react": "19.2.0",
		"react-dom": "19.2.0",
		"react-native": "0.83.2",
		"react-native-gesture-handler": "~2.30.0",
		"react-native-nitro-modules": "^0.35.0",
		"react-native-reanimated": "4.2.1",
		"react-native-safe-area-context": "~5.6.2",
		"react-native-screens": "~4.23.0",
		"react-native-skia-yoga": "link:../",
		"react-native-web": "^0.21.2",
		"react-native-webview": "13.16.0",
		"react-native-worklets": "0.7.2"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@types/react": "~19.2.10",
		"eslint": "^9.39.4",
		"eslint-config-expo": "~55.0.0",
		"typescript": "~5.9.3"
	},
	"private": true,
	"expo": {
		"autolinking": {
			"searchPaths": [
				"./node_modules",
				"../node_modules"
			]
		}
	},
	"trustedDependencies": [
		"react-native-nitro-modules",
		"unrs-resolver"
	]
}
