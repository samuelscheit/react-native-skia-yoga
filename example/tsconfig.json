{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react-native-skia-yoga",
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ],
      "react-native-skia-yoga": [
        "../"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
